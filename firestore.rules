
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // USERS collection
    match /users/{userId} {
      // Allow user creation on signup, or if the user is an admin.
      // A user can update their own data.
      allow create: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // A user can read their own data, or if the user is an admin.
      allow read, update: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // Only admins can delete users.
      allow delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // INVITES collection
    match /invites/{inviteId} {
      // Any authenticated user can read invites (to check for their own invite).
      allow read: if request.auth.uid != null;

      // Only admins can create, update, or delete invites.
      allow create, update, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // REPORTS collection
    match /reports/{reportId} {
      // Any authenticated user can read all reports (for dashboards) and create new ones.
      allow read, create: if request.auth.uid != null;
      
      // A user can update/delete their own reports. An admin can also update/delete any report.
      allow update, delete: if request.auth.uid == resource.data.teacherId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
