rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // USER documents can be read by their owner or an admin.
    // They can only be written to by their owner. This protects the 'role'.
    match /users/{userId} {
      allow read: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow write: if request.auth.uid == userId;
    }

    // INVITES can be read by anyone (necessary for pre-registration check).
    // They can only be created by an admin.
    // They can be updated by any authenticated user (to complete their own invite).
    match /invites/{inviteId} {
      allow read, update: if true;
      allow create: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // REPORTS can be read by any authenticated user (for dashboards).
    // They can only be written/deleted by their owner (teacherId) or an admin.
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow write, delete: if request.auth != null && (request.resource.data.teacherId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
  }
}
