
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the requesting user is an admin.
    function isAdmin() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users can manage their own document. Admins can read any user's document.
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if request.auth.uid == userId;
    }

    // Invites can be created by admins.
    // They can be read by any authenticated user to allow for invite verification on the client.
    // They can be updated by any authenticated user to allow them to complete their own invite upon registration.
    match /invites/{inviteId} {
      allow read: if request.auth != null;
      allow create: if isAdmin();
      allow update: if request.auth != null;
      allow delete: if isAdmin();
    }

    // Reports can be created by any authenticated user for themselves.
    // They can be read by any authenticated user (for dashboards).
    // They can only be updated/deleted by their creator (teacherId) or an admin.
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.teacherId == request.auth.uid || isAdmin());
    }
  }
}
